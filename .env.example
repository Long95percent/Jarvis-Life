# ============================================================
# ShadowLink — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# The setup_and_run.bat script will guide you through this
# on first run.
# ============================================================

# ── LLM Provider ──
# Base URL for OpenAI-compatible API
SHADOWLINK_LLM_BASE_URL=https://api.openai.com/v1

# Your API key (required)
SHADOWLINK_LLM_API_KEY=sk-your-key-here

# Model name
SHADOWLINK_LLM_MODEL=gpt-4o

# ── Java Backend Profile ──
# "dev" uses H2 in-memory database (no MySQL/Redis needed)
# "prod" requires MySQL + Redis
SPRING_PROFILES_ACTIVE=dev

# ── Service Ports (defaults shown, rarely need changing) ──
# AI_PORT=8000
# GATEWAY_PORT=8080
# WEB_PORT=3000
